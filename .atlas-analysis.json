  "keyFeatures": [
    "Patient management with medical records and profiles",
    "Doctor scheduling with availability management",
    "Appointment booking with time slot validation",
    "Medical consultations with prescriptions and treatment records",
    "Pet cardex for veterinary care",
    "Multi-authentication (email, Firebase, social login)",
    "Role-based access control (admin, doctor, patient)",
    "Email notifications for appointments",
    "Chatbot for appointment assistance",
    "Oracle database integration with Yajra OCI8",
    "Analytics integration with Apache Superset"
  ],
